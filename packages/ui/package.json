{
  "name": "@tribulnation/ui",
  "version": "0.1.0",
  "description": "Tribulnation Labs shared design system: tokens, hash-driven light/dark/system + brand axes, logo marks, and font loading.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tribulnation/design.git",
    "directory": "packages/ui"
  },
  "homepage": "https://tribulnation.github.io/design/",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "package": "svelte-package && publint",
    "prepublishOnly": "npm run package",
    "check": "svelte-check --tsconfig ./tsconfig.json"
  },
  "files": [
    "dist"
  ],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    },
    "./tokens.css": "./dist/tokens.css",
    "./marks.css": "./dist/marks.css",
    "./design-axes": {
      "types": "./dist/design-axes.d.ts",
      "default": "./dist/design-axes.js"
    },
    "./fonts": {
      "types": "./dist/fonts.d.ts",
      "default": "./dist/fonts.js"
    }
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.3.7",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "publint": "^0.2.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.6.0"
  }
}
